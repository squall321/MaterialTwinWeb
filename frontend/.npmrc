# Vite's transitive deps (esbuild, rollup) are imported by vite/dist/node/cli.js
# at runtime via package resolution. pnpm's default symlink layout puts them
# in node_modules/.pnpm only — vite then can't find them. shamefully-hoist
# flattens everything to top-level node_modules (like npm/yarn) so resolution
# succeeds.
shamefully-hoist=true
auto-install-peers=true
